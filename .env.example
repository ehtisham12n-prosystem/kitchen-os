# Runtime
NODE_ENV=development
PORT=3000

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kitchenos
DB_USERNAME=kitchenos
DB_PASSWORD=change_me
DB_ROOT_PASSWORD=change_root_password_for_docker_only

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=12h

# CORS
# Local defaults are applied automatically when CORS_ALLOWED_ORIGINS is omitted in development.
# Staging/production must set explicit browser origins.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5190,http://127.0.0.1:5190
CORS_ALLOW_CREDENTIALS=true

# Security retention
SECURITY_SESSION_RETENTION_DAYS=90
SECURITY_ACCESS_LOG_RETENTION_DAYS=180
SECURITY_AUTH_AUDIT_RETENTION_DAYS=365

# Operational backup checks
BACKUP_STORAGE_PATH=
BACKUP_RETENTION_DAYS=
BACKUP_RESTORE_VALIDATION_ENABLED=false

# First-run bootstrap
BOOTSTRAP_SUPER_ADMIN_FULL_NAME=KitchenOS Super Admin
BOOTSTRAP_SUPER_ADMIN_USERNAME=superadmin
BOOTSTRAP_SUPER_ADMIN_EMAIL=superadmin@example.com
BOOTSTRAP_SUPER_ADMIN_PASSWORD=change_me

# Optional first client bootstrap
BOOTSTRAP_CLIENT_ID=CL-10001
BOOTSTRAP_CLIENT_CODE=TEN-10001
BOOTSTRAP_CLIENT_NAME=Kitchen Club
BOOTSTRAP_CLIENT_LEGAL_NAME=Kitchen Club (Pvt.) Ltd.
BOOTSTRAP_CLIENT_SHORT_NAME=Kitchen Club
BOOTSTRAP_CLIENT_SLUG=kitchen-club
BOOTSTRAP_CLIENT_BUSINESS_TYPE=restaurant
BOOTSTRAP_CLIENT_CURRENCY=PKR
BOOTSTRAP_CLIENT_LANGUAGE=en
BOOTSTRAP_CLIENT_TIMEZONE=Asia/Karachi
BOOTSTRAP_CLIENT_PLAN_CODE=START-01
BOOTSTRAP_CLIENT_ADMIN_FULL_NAME=Kitchen Club Admin
BOOTSTRAP_CLIENT_ADMIN_USERNAME=kitchenclub.admin
BOOTSTRAP_CLIENT_ADMIN_EMAIL=admin@kitchenclub.local
BOOTSTRAP_CLIENT_ADMIN_PASSWORD=change_me
BOOTSTRAP_CLIENT_STARTER_PROFILE=kitchen-club
BOOTSTRAP_CLIENT_BRANCH_MANAGER_PASSWORD=change_me
BOOTSTRAP_CLIENT_CASHIER_PASSWORD=change_me
